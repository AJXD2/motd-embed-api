# ============================================================
# Server Configuration
# ============================================================

# Host to bind to (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Port to run the server on
PORT=8000

# Enable auto-reload for development (set to false in production)
RELOAD=false

# Logging level: debug, info, warning, error, critical
LOG_LEVEL=info

# ============================================================
# CORS Configuration
# ============================================================
# Comma-separated list of allowed origins.
# Use "*" only for development/testing.
# For production: ALLOWED_ORIGINS=https://example.com,https://app.example.com
ALLOWED_ORIGINS=*

# ============================================================
# Cache Configuration
# ============================================================

# Time-to-live for cached server status responses (seconds)
CACHE_TTL_SECONDS=30

# Maximum number of servers to hold in the cache at once
CACHE_MAXSIZE=1000

# ============================================================
# Server Query Configuration
# ============================================================

# Timeout (seconds) when connecting to a Minecraft server
SERVER_TIMEOUT=5.0

# Maximum hostname length (chars); rejects absurdly long addresses
SERVER_ADDRESS_MAX_LENGTH=253

# ============================================================
# Rate Limiting  (slowapi format: "<count>/<period>")
# ============================================================

RATE_LIMIT_EMBED=30/minute
RATE_LIMIT_IMAGE=10/minute
RATE_LIMIT_HEALTH=60/minute

# ============================================================
# Input Limits
# ============================================================

# Maximum MOTD length in characters before truncation
MOTD_MAX_LENGTH=2048

# Maximum favicon data URI length in bytes
FAVICON_MAX_BYTES=150000

# ============================================================
# Observability
# ============================================================

# Expose Prometheus metrics at /metrics (true/false)
# Restrict /metrics at the ingress/network layer in production (no auth built-in)
METRICS_ENABLED=true

# ============================================================
# Static Files
# ============================================================

# Absolute path to the static/ directory.
# Defaults to auto-detect from package location.
# Set explicitly when using Docker volume mounts or non-standard layouts.
# STATIC_DIR=/app/static
